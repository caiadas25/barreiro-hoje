---
import Layout from '../layouts/Layout.astro';
import mapData from '../data/barreiro-map.json';
import freguesias from '../data/freguesias.json';

const totalPop  = freguesias.reduce((s, f) => s + f.population, 0);
const totalArea = freguesias.reduce((s, f) => s + f.area_km2, 0);

// Emblem parish colors keyed by id
const FREG_COLORS: Record<string, string> = {
  'alto-do-seixalinho':     '#BDA15A',
  'barreiro-lavradio':      '#5C7FA0',
  'palhais-coina':          '#8FA987',
  'santo-antonio-charneca': '#8A7A99',
};
---

<Layout title="Mapa das Freguesias — Barreiro Digest" activeNav="mapa">
  <main class="wrap-wide fade-in" style="padding-bottom:64px;">

    <div class="pagehead">
      <div class="eyebrow">O município</div>
      <h1 class="page-title">Mapa das Freguesias</h1>
      <p class="page-sub">As quatro freguesias do Barreiro — população, área e contactos das juntas.</p>
    </div>

    <!-- Stats bar -->
    <div class="statbar">
      <div class="stat-card">
        <div class="stat-label">População</div>
        <div class="stat-value">{totalPop.toLocaleString('pt-PT')}</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Área</div>
        <div class="stat-value">{totalArea.toFixed(1)} km²</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Freguesias</div>
        <div class="stat-value">{freguesias.length}</div>
      </div>
    </div>

    <div class="map-grid">
      <!-- Map -->
      <div>
        <div class="map-panel">
          <svg
            viewBox={mapData.viewBox}
            style="width:100%;height:auto;"
            id="barreiro-map"
            role="img"
            aria-label="Mapa das freguesias de Barreiro"
          >
            {mapData.regions.map((r) => {
              const col = FREG_COLORS[r.id] || r.color;
              return (
                <path
                  d={r.path}
                  fill={col}
                  fill-opacity="0.62"
                  stroke="var(--color-paper)"
                  stroke-width="2"
                  class="map-region"
                  data-id={r.id}
                  data-color={col}
                  tabindex="0"
                  role="button"
                  aria-label={r.name}
                />
              );
            })}
            {mapData.regions.map((r) => (
              <text
                x={r.centerX}
                y={r.centerY}
                text-anchor="middle"
                dominant-baseline="middle"
                class="map-label"
              >
                {r.name}
              </text>
            ))}
          </svg>
        </div>
        <p class="map-hint">Clique numa freguesia para ver detalhes</p>

        <!-- Tooltip -->
        <div id="map-tooltip" class="map-tooltip">
          <div id="tooltip-name" class="tooltip-name"></div>
          <div id="tooltip-sub"  class="tooltip-sub"></div>
        </div>
      </div>

      <!-- Detail + quick-access column -->
      <div>
        <!-- Default state -->
        <div id="panel-default" class="detail-panel">
          <div class="detail-name" style="font-size:18px;">Selecione uma freguesia</div>
          <p style="font-size:14px;color:var(--color-ink-2);margin-top:8px;line-height:1.5;">
            Clique no mapa ou nos cartões abaixo para ver dados populacionais e contactos.
          </p>
        </div>

        <!-- Detail state (hidden until a parish is selected) -->
        <div id="panel-detail" class="detail-panel" style="display:none;">
          <div style="display:flex;align-items:center;gap:10px;">
            <span id="detail-dot"  class="freg-dot"></span>
            <span id="detail-name" class="detail-name"></span>
          </div>
          <p id="detail-fullname" class="detail-fullname"></p>

          <div class="mini-stats">
            <div class="mini-stat">
              <div class="mini-stat-label">População</div>
              <div id="detail-pop" class="mini-stat-value"></div>
            </div>
            <div class="mini-stat">
              <div class="mini-stat-label">Área</div>
              <div id="detail-area" class="mini-stat-value"></div>
            </div>
            <div class="mini-stat">
              <div class="mini-stat-label">Densidade</div>
              <div id="detail-density" class="mini-stat-value"></div>
            </div>
          </div>

          <div class="detail-section">
            <h4 class="detail-section-label">Presidente da Junta</h4>
            <div id="detail-presidente" style="font-size:14px;color:var(--color-ink);font-weight:500;"></div>
            <div id="detail-presidente-info" style="font-size:13px;color:var(--color-ink-3);margin-top:2px;"></div>
          </div>

          <div class="detail-section">
            <h4 class="detail-section-label">Freguesias componente</h4>
            <div id="detail-parishes" class="parish-tags"></div>
          </div>

          <div class="detail-section">
            <h4 class="detail-section-label">Contacto</h4>
            <div class="contact-row">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>
              <span id="detail-address"></span>
            </div>
            <div class="contact-row">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.13 12.72 19.79 19.79 0 0 1 1.06 4.1 2 2 0 0 1 3 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              <a id="detail-phone" href=""></a>
            </div>
            <div class="contact-row">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              <a id="detail-email" href=""></a>
            </div>
            <div class="contact-row">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
              <a id="detail-website" href="" target="_blank" rel="noopener"></a>
            </div>
          </div>
        </div>

        <!-- Quick-access cards -->
        <div style="margin-top:14px;" id="freg-cards">
          {freguesias.map((f) => {
            const col = FREG_COLORS[f.id] || f.color;
            return (
              <button class="freg-card" data-id={f.id}>
                <span class="freg-dot" style={`background:${col}`}></span>
                <span class="freg-name">{f.shortName}</span>
                <span class="freg-pop">{f.population.toLocaleString('pt-PT')} hab.</span>
              </button>
            );
          })}
        </div>
      </div>
    </div>

  </main>
</Layout>

<script define:vars={{ frequesiasData: freguesias, fregColors: FREG_COLORS }}>
  const byId     = Object.fromEntries(frequesiasData.map(f => [f.id, f]));
  const regions  = document.querySelectorAll('.map-region');
  const cards    = document.querySelectorAll('.freg-card');
  const tooltip  = document.getElementById('map-tooltip');
  let   active   = null;

  const $ = id => document.getElementById(id);

  function fmt(n) { return Number(n).toLocaleString('pt-PT'); }
  function safe(v) { return v && v !== 'VERIFICAR' ? v : 'A verificar'; }

  function showDetail(id) {
    const f = byId[id];
    if (!f) return;
    const col = fregColors[id] || f.color;

    $('detail-dot').style.background = col;
    $('detail-name').textContent      = f.shortName;
    $('detail-fullname').textContent  = f.name;
    $('detail-pop').textContent       = fmt(f.population);
    $('detail-area').textContent      = f.area_km2.toFixed(1) + ' km²';
    $('detail-density').textContent   = fmt(Math.round(f.population / f.area_km2));

    $('detail-presidente').textContent      = safe(f.presidente_junta);
    $('detail-presidente-info').textContent = f.presidente_junta && f.presidente_junta !== 'VERIFICAR'
      ? `${f.presidente_partido || ''} · ${f.mandato || ''}` : '';

    $('detail-parishes').innerHTML = (f.componentParishes || [])
      .map(p => `<span class="parish-tag">${p}</span>`).join('');

    $('detail-address').textContent = safe(f.address);

    const phone = $('detail-phone');
    phone.textContent = safe(f.phone);
    phone.href = f.phone && f.phone !== 'VERIFICAR' ? 'tel:' + f.phone.replace(/\s/g,'') : '';

    const email = $('detail-email');
    email.textContent = safe(f.email);
    email.href = f.email && f.email !== 'VERIFICAR' ? 'mailto:' + f.email : '';

    const site = $('detail-website');
    site.textContent = f.website ? f.website.replace(/^https?:\/\//, '') : 'A verificar';
    site.href = f.website || '';

    $('panel-default').style.display = 'none';
    $('panel-detail').style.display  = 'block';

    regions.forEach(r => {
      const isSel = r.dataset.id === id;
      r.setAttribute('fill-opacity', isSel ? '0.92' : active ? '0.3' : '0.62');
      r.setAttribute('stroke',      isSel ? col : 'var(--color-paper)');
      r.setAttribute('stroke-width', isSel ? '3' : '2');
    });

    cards.forEach(c => c.classList.toggle('active', c.dataset.id === id));
    active = id;
  }

  function resetMap() {
    $('panel-default').style.display = 'block';
    $('panel-detail').style.display  = 'none';
    regions.forEach(r => {
      r.setAttribute('fill-opacity', '0.62');
      r.setAttribute('stroke', 'var(--color-paper)');
      r.setAttribute('stroke-width', '2');
    });
    cards.forEach(c => c.classList.remove('active'));
    active = null;
  }

  regions.forEach(region => {
    region.addEventListener('click', () => {
      tooltip.style.opacity = '0';
      region.dataset.id === active ? resetMap() : showDetail(region.dataset.id);
    });
    region.addEventListener('keydown', e => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        region.dataset.id === active ? resetMap() : showDetail(region.dataset.id);
      }
    });
    region.addEventListener('mouseenter', e => {
      if (region.dataset.id !== active) region.setAttribute('fill-opacity', '0.8');
      const f = byId[region.dataset.id];
      if (f) {
        $('tooltip-name').textContent = f.shortName;
        $('tooltip-sub').textContent  = fmt(f.population) + ' hab. · ' + f.area_km2.toFixed(1) + ' km²';
        tooltip.style.opacity = '1';
      }
    });
    region.addEventListener('mousemove', e => {
      tooltip.style.left = (e.clientX + 14) + 'px';
      tooltip.style.top  = (e.clientY - 10) + 'px';
    });
    region.addEventListener('mouseleave', () => {
      if (region.dataset.id !== active) region.setAttribute('fill-opacity', '0.62');
      tooltip.style.opacity = '0';
    });
  });

  cards.forEach(card => {
    card.addEventListener('click', () =>
      card.dataset.id === active ? resetMap() : showDetail(card.dataset.id)
    );
  });
</script>
