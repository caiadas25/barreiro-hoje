---
import Layout from '../layouts/Layout.astro';
import mapData from '../data/barreiro-map.json';
import freguesias from '../data/freguesias.json';

const totalPop = freguesias.reduce((sum, f) => sum + f.population, 0);
const totalArea = freguesias.reduce((sum, f) => sum + f.area_km2, 0);
---

<Layout title="Mapa de Barreiro - Barreiro Digest">
  <main class="max-w-6xl mx-auto px-4 py-8">
    <header class="mb-8">
      <a href="/" class="text-[#FF8C2F] hover:underline text-sm">← Voltar</a>
      <h1 class="text-3xl font-bold text-[#FF8C2F] mt-4">Mapa de Barreiro</h1>
      <p class="text-[#999999] mt-2">As {freguesias.length} freguesias do município</p>
    </header>

    <!-- Stats bar -->
    <div class="flex gap-6 mb-8 text-sm">
      <div class="bg-[#252525] rounded-lg px-4 py-3 border border-[#333333]">
        <span class="text-[#999999]">População</span>
        <span class="text-white font-semibold ml-2">{totalPop.toLocaleString('pt-PT')}</span>
      </div>
      <div class="bg-[#252525] rounded-lg px-4 py-3 border border-[#333333]">
        <span class="text-[#999999]">Área</span>
        <span class="text-white font-semibold ml-2">{totalArea.toFixed(1)} km²</span>
      </div>
      <div class="bg-[#252525] rounded-lg px-4 py-3 border border-[#333333]">
        <span class="text-[#999999]">Freguesias</span>
        <span class="text-white font-semibold ml-2">{freguesias.length}</span>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-6">
      <!-- Map column -->
      <div class="lg:col-span-3">
        <div class="bg-[#252525] rounded-lg p-4 border border-[#333333]">
          <svg 
            viewBox={mapData.viewBox}
            class="w-full h-auto"
            id="barreiro-map"
            role="img"
            aria-label="Mapa das freguesias de Barreiro"
          >
            {mapData.regions.map((region) => (
              <path
                d={region.path}
                fill={region.color}
                fill-opacity="0.6"
                stroke="#1C1B1B"
                stroke-width="2"
                class="map-region cursor-pointer transition-all duration-200"
                data-id={region.id}
                data-name={region.name}
                data-full-name={region.fullName}
                data-color={region.color}
                tabindex="0"
                role="button"
                aria-label={region.fullName}
              />
            ))}
            {mapData.regions.map((region) => (
              <text
                x={region.centerX}
                y={region.centerY}
                text-anchor="middle"
                dominant-baseline="middle"
                class="pointer-events-none select-none text-[11px] font-semibold fill-white drop-shadow-lg"
              >
                {region.name}
              </text>
            ))}
          </svg>
        </div>
        <p class="text-xs text-[#666] mt-2 text-center">Clique numa freguesia para ver detalhes</p>
        
        <!-- Hover tooltip -->
        <div id="map-tooltip" class="fixed pointer-events-none z-50 bg-[#1C1B1B] border border-[#333333] rounded-lg px-3 py-2 shadow-xl opacity-0 transition-opacity duration-150">
          <p id="tooltip-name" class="text-sm font-semibold text-white"></p>
          <p id="tooltip-pop" class="text-xs text-[#999999]"></p>
        </div>
      </div>

      <!-- Detail panel -->
      <div class="lg:col-span-2">
        <div id="detail-panel" class="bg-[#252525] rounded-lg border border-[#333333] overflow-hidden transition-all duration-300">
          <!-- Default state -->
          <div id="panel-default" class="p-6">
            <h2 class="text-lg font-semibold text-[#FF8C2F] mb-3">Selecione uma freguesia</h2>
            <p class="text-[#999999] text-sm">Clique no mapa ou nos cards abaixo para ver informações de contacto e dados populacionais.</p>
          </div>

          <!-- Detail state (hidden by default) -->
          <div id="panel-detail" class="hidden">
            <div class="p-6">
              <div class="flex items-center gap-3 mb-4">
                <div id="detail-color-dot" class="w-4 h-4 rounded-full"></div>
                <h2 id="detail-name" class="text-lg font-semibold"></h2>
              </div>
              <p id="detail-full-name" class="text-xs text-[#666] mb-4 italic"></p>

              <!-- Stats: Population, Area, Density -->
              <div class="grid grid-cols-3 gap-3 mb-5">
                <div class="bg-[#1C1B1B] rounded-lg p-3">
                  <span class="text-[10px] text-[#999999] uppercase tracking-wider">População</span>
                  <p id="detail-population" class="text-xl font-bold text-white"></p>
                  <p class="text-[9px] text-[#666]">Censos 2021</p>
                </div>
                <div class="bg-[#1C1B1B] rounded-lg p-3">
                  <span class="text-[10px] text-[#999999] uppercase tracking-wider">Área</span>
                  <p id="detail-area" class="text-xl font-bold text-white"></p>
                </div>
                <div class="bg-[#1C1B1B] rounded-lg p-3">
                  <span class="text-[10px] text-[#999999] uppercase tracking-wider">Densidade</span>
                  <p id="detail-density" class="text-xl font-bold text-white"></p>
                  <p class="text-[9px] text-[#666]">hab/km²</p>
                </div>
              </div>

              <!-- Presidente da Junta -->
              <div id="detail-presidente-section" class="mb-5">
                <h3 class="text-xs font-semibold text-[#999999] uppercase tracking-wider mb-2">Presidente da Junta</h3>
                <div class="bg-[#1C1B1B] rounded-lg p-3">
                  <p id="detail-presidente-name" class="text-sm text-white font-medium"></p>
                  <p id="detail-presidente-info" class="text-xs text-[#999999] mt-1"></p>
                </div>
              </div>

              <!-- Component parishes -->
              <div id="detail-parishes-section" class="mb-5">
                <h3 class="text-xs font-semibold text-[#999999] uppercase tracking-wider mb-2">Freguesias componente</h3>
                <div id="detail-parishes" class="flex flex-wrap gap-2"></div>
              </div>

              <!-- Contact info -->
              <div class="space-y-3">
                <h3 class="text-xs font-semibold text-[#999999] uppercase tracking-wider">Contacto</h3>
                
                <div class="flex items-start gap-3 text-sm">
                  <span class="text-[#FF8C2F] mt-0.5">📍</span>
                  <span id="detail-address" class="text-[#ccc]"></span>
                </div>
                
                <div class="flex items-center gap-3 text-sm">
                  <span class="text-[#FF8C2F]">📞</span>
                  <a id="detail-phone" href="" class="text-[#ccc] hover:text-[#FF8C2F]"></a>
                </div>
                
                <div class="flex items-center gap-3 text-sm">
                  <span class="text-[#FF8C2F]">✉️</span>
                  <a id="detail-email" href="" class="text-[#ccc] hover:text-[#FF8C2F]"></a>
                </div>
                
                <div class="flex items-center gap-3 text-sm">
                  <span class="text-[#FF8C2F]">🌐</span>
                  <a id="detail-website" href="" target="_blank" rel="noopener noreferrer" class="text-[#ccc] hover:text-[#FF8C2F]"></a>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Quick-access cards -->
        <div class="mt-4 space-y-2">
          {freguesias.map((f) => (
            <button
              class="freg-card w-full text-left bg-[#252525] rounded-lg p-3 border border-[#333333] hover:border-[#FF8C2F] transition-colors cursor-pointer"
              data-id={f.id}
            >
              <div class="flex items-center gap-3">
                <div class="w-3 h-3 rounded-full" style={`background-color: ${f.color}`}></div>
                <span class="text-sm font-medium text-white">{f.shortName}</span>
                <span class="text-xs text-[#999999] ml-auto">{f.population.toLocaleString('pt-PT')} hab.</span>
              </div>
            </button>
          ))}
        </div>
      </div>
    </div>
  </main>
</Layout>

<script define:vars={{ freguesiasData: freguesias }}>
  const freguesiasMap = Object.fromEntries(freguesiasData.map(f => [f.id, f]));
  
  const panel = document.getElementById('detail-panel');
  const panelDefault = document.getElementById('panel-default');
  const panelDetail = document.getElementById('panel-detail');
  const regions = document.querySelectorAll('.map-region');
  const cards = document.querySelectorAll('.freg-card');

  let activeRegion = null;
  const tooltip = document.getElementById('map-tooltip');
  const tooltipName = document.getElementById('tooltip-name');
  const tooltipPop = document.getElementById('tooltip-pop');

  function safeValue(val, fallback) {
    return val && val !== 'VERIFICAR' ? val : fallback;
  }

  function showDetail(freguesiaId) {
    const f = freguesiasMap[freguesiaId];
    if (!f) return;

    const density = Math.round(f.population / f.area_km2);

    // Update panel
    document.getElementById('detail-color-dot').style.backgroundColor = f.color;
    document.getElementById('detail-name').textContent = f.shortName;
    document.getElementById('detail-full-name').textContent = f.name;
    document.getElementById('detail-population').textContent = f.population.toLocaleString('pt-PT');
    document.getElementById('detail-area').textContent = f.area_km2.toFixed(1) + ' km²';
    document.getElementById('detail-density').textContent = density.toLocaleString('pt-PT');

    // Presidente
    const presidenteName = document.getElementById('detail-presidente-name');
    const presidenteInfo = document.getElementById('detail-presidente-info');
    if (f.presidente_junta && f.presidente_junta !== 'VERIFICAR') {
      presidenteName.textContent = f.presidente_junta;
      presidenteInfo.textContent = `${f.presidente_partido || ''} · ${f.mandato || ''}`;
    } else {
      presidenteName.textContent = 'A verificar';
      presidenteInfo.textContent = '';
    }

    // Address
    const addressEl = document.getElementById('detail-address');
    addressEl.textContent = safeValue(f.address, 'A verificar');

    // Phone
    const phoneLink = document.getElementById('detail-phone');
    if (f.phone && f.phone !== 'VERIFICAR') {
      phoneLink.href = 'tel:' + f.phone.replace(/\s/g, '');
      phoneLink.textContent = f.phone;
      phoneLink.classList.remove('pointer-events-none');
    } else {
      phoneLink.textContent = 'A verificar';
      phoneLink.href = '';
      phoneLink.classList.add('pointer-events-none');
    }

    // Email
    const emailLink = document.getElementById('detail-email');
    if (f.email && f.email !== 'VERIFICAR') {
      emailLink.href = 'mailto:' + f.email;
      emailLink.textContent = f.email;
      emailLink.classList.remove('pointer-events-none');
    } else {
      emailLink.textContent = 'A verificar';
      emailLink.href = '';
      emailLink.classList.add('pointer-events-none');
    }

    // Website
    const websiteLink = document.getElementById('detail-website');
    if (f.website && f.website !== 'VERIFICAR') {
      websiteLink.href = f.website;
      websiteLink.textContent = f.website.replace('https://', '');
      websiteLink.classList.remove('pointer-events-none');
    } else {
      websiteLink.textContent = 'A verificar';
      websiteLink.href = '';
      websiteLink.classList.add('pointer-events-none');
    }

    // Component parishes
    const parishesContainer = document.getElementById('detail-parishes');
    parishesContainer.innerHTML = f.componentParishes
      .map(p => `<span class="bg-[#1C1B1B] text-xs text-[#ccc] px-2 py-1 rounded">${p}</span>`)
      .join('');

    // Show detail, hide default
    panelDefault.classList.add('hidden');
    panelDetail.classList.remove('hidden');

    // Highlight map region
    regions.forEach(r => {
      if (r.dataset.id === freguesiaId) {
        r.setAttribute('fill-opacity', '0.9');
        r.setAttribute('stroke', f.color);
        r.setAttribute('stroke-width', '3');
      } else {
        r.setAttribute('fill-opacity', '0.3');
        r.setAttribute('stroke', '#1C1B1B');
        r.setAttribute('stroke-width', '2');
      }
    });

    // Highlight card
    cards.forEach(c => {
      if (c.dataset.id === freguesiaId) {
        c.classList.add('border-[#FF8C2F]');
      } else {
        c.classList.remove('border-[#FF8C2F]');
      }
    });

    activeRegion = freguesiaId;
  }

  function resetMap() {
    panelDefault.classList.remove('hidden');
    panelDetail.classList.add('hidden');
    regions.forEach(r => {
      r.setAttribute('fill-opacity', '0.6');
      r.setAttribute('stroke', '#1C1B1B');
      r.setAttribute('stroke-width', '2');
    });
    cards.forEach(c => c.classList.remove('border-[#FF8C2F]'));
    activeRegion = null;
  }

  // Map region clicks
  regions.forEach(region => {
    region.addEventListener('click', () => {
      tooltip.style.opacity = '0';
      const id = region.dataset.id;
      if (id === activeRegion) {
        resetMap();
      } else {
        showDetail(id);
      }
    });

    // Keyboard accessibility
    region.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        const id = region.dataset.id;
        if (id === activeRegion) {
          resetMap();
        } else {
          showDetail(id);
        }
      }
    });

    region.addEventListener('mouseenter', (e) => {
      if (region.dataset.id !== activeRegion) {
        region.setAttribute('fill-opacity', '0.8');
      }
      // Show tooltip
      const id = region.dataset.id;
      const f = freguesiasMap[id];
      if (f) {
        tooltipName.textContent = f.shortName;
        tooltipPop.textContent = f.population.toLocaleString('pt-PT') + ' hab. · ' + f.area_km2.toFixed(1) + ' km²';
        tooltip.style.opacity = '1';
      }
    });

    region.addEventListener('mousemove', (e) => {
      tooltip.style.left = (e.clientX + 12) + 'px';
      tooltip.style.top = (e.clientY - 8) + 'px';
    });

    region.addEventListener('mouseleave', () => {
      if (region.dataset.id !== activeRegion) {
        region.setAttribute('fill-opacity', '0.6');
      }
      tooltip.style.opacity = '0';
    });
  });

  // Card clicks
  cards.forEach(card => {
    card.addEventListener('click', () => {
      const id = card.dataset.id;
      if (id === activeRegion) {
        resetMap();
      } else {
        showDetail(id);
      }
    });
  });
</script>
