---
import Layout from '../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const digests = await getCollection('digests');
  return digests.map((digest) => ({
    params: { slug: digest.id },
    props:  { digest },
  }));
}

const { digest } = Astro.props;
const { Content } = await render(digest);

const fmtDate = (iso: string) =>
  new Date(iso + 'T00:00:00').toLocaleDateString('pt-PT', {
    weekday: 'long', year: 'numeric', month: 'long', day: 'numeric',
  });
---

<Layout title={`${digest.data.title} — Barreiro Hoje`} activeNav="arquivo">
  <main class="wrap fade-in" style="padding-bottom:64px;">

    <div class="pagehead" style="padding-bottom:8px;">
      <a href="/" class="btn btn-secondary" style="padding:7px 16px;font-size:13px;">← Voltar</a>
    </div>

    <div class="digest-card">
      <div class="digest-date">{fmtDate(digest.data.date)}</div>
      <h1 class="digest-title" style="font-size:clamp(26px,4vw,36px);">{digest.data.title}</h1>

      <div class="digest-prose" style="margin-top:24px;">
        <Content />
      </div>

      {digest.data.sources && digest.data.sources.length > 0 && (
        <div class="sources-block">
          <h3 class="sources-label">Fontes</h3>
          <div>
            {digest.data.sources.map((s) => (
              <a href={s.url} target="_blank" rel="noopener" class="source-link">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
                {s.name}
              </a>
            ))}
          </div>
        </div>
      )}
    </div>

  </main>
</Layout>
