---
import Layout from '../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

const digests = (await getCollection('digests')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const latest  = digests[0];
const archive = digests.slice(1);

const latestRender = latest ? await render(latest) : null;
const LatestContent = latestRender?.Content;

const fmtDate  = (iso: string) =>
  new Date(iso + 'T00:00:00').toLocaleDateString('pt-PT', {
    weekday: 'long', year: 'numeric', month: 'long', day: 'numeric',
  });
const fmtShort = (iso: string) =>
  new Date(iso + 'T00:00:00').toLocaleDateString('pt-PT', {
    day: '2-digit', month: 'short',
  });

const countStories = (body: string) => (body.match(/^### /gm) || []).length;
---

<Layout title="Barreiro Hoje" activeNav="hoje">
  <main class="wrap fade-in" style="padding-bottom:64px;">

    <div class="pagehead">
      <div class="eyebrow">Edição de hoje</div>
      <h1 class="page-title">Notícias do Barreiro</h1>
      <p class="page-sub">O essencial do município, todos os dias. Câmara, transportes, obras e eventos — num só lugar.</p>
    </div>

    {latest && LatestContent && (
      <div class="digest-card">
        <div class="digest-date">{fmtDate(latest.data.date)}</div>
        <h2 class="digest-title">{latest.data.title}</h2>

        <div class="digest-prose" style="margin-top:20px;">
          <LatestContent />
        </div>

        {latest.data.sources && latest.data.sources.length > 0 && (
          <div class="sources-block">
            <h3 class="sources-label">Fontes</h3>
            <div>
              {latest.data.sources.map((s) => (
                <a href={s.url} target="_blank" rel="noopener" class="source-link">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
                  {s.name}
                </a>
              ))}
            </div>
          </div>
        )}

        <div style="margin-top:20px;">
          <a href={`/${latest.id}`} class="btn btn-secondary" style="font-size:13.5px;">
            Ver edição completa →
          </a>
        </div>
      </div>
    )}

    {archive.length > 0 && (
      <section style="margin-top:48px;">
        <h3 class="section-label">Arquivo recente</h3>
        {archive.map((d) => {
          const n = countStories(d.body || '');
          return (
            <a href={`/${d.id}`} class="arch-row">
              <span class="arch-date">{fmtShort(d.data.date)}</span>
              <span class="arch-title">{d.data.title.replace(/ —.*/, '')}</span>
              {n > 0 && (
                <span class="arch-count">{n} {n === 1 ? 'notícia' : 'notícias'}</span>
              )}
            </a>
          );
        })}
      </section>
    )}

  </main>
</Layout>
