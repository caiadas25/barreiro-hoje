---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="pt">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content="Barreiro Digest - Notícias diárias do Barreiro" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-[#1C1B1B] text-white">
    <slot />
  </body>
</html>
